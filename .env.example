# ============================================
# 随行档 - 环境变量配置模板
# 复制为 .env 并填写实际值
# ============================================

# --- 服务器配置 ---
DOMAIN=files.yourdomain.com
# 兼容回退密钥：未单独配置 JWT_SECRET / DATA_ENCRYPTION_KEY 时使用。
# 生产环境强烈建议分别设置下面两个独立密钥（openssl rand -hex 32）。
SECRET_KEY=请替换为一个随机长字符串（openssl rand -hex 32）
# JWT 签名密钥（独立于数据加密密钥，轮换互不影响）。为空则回退 SECRET_KEY。
JWT_SECRET=请替换为一个独立随机串（openssl rand -hex 32）
# 静态数据加密主密钥（Fernet 派生用）。为空则回退 SECRET_KEY。
DATA_ENCRYPTION_KEY=请替换为另一个独立随机串（openssl rand -hex 32）
# CORS 允许来源（逗号分隔）。为空时按 DOMAIN 派生 https://<DOMAIN>。
# CORS_ORIGINS=https://files.yourdomain.com,https://alt.yourdomain.com
# 受信任反向代理 IP（逗号分隔）。仅当直连对端在此集合内时才信任 X-Forwarded-For；
# 否则用 TCP 对端 IP，防止直连 :8000 时伪造 XFF 绕过登录限流。Caddy 部署建议填 Caddy 容器 IP。
# TRUSTED_PROXIES=172.18.0.3

# --- 管理员账户（首次启动自动创建）---
ADMIN_USERNAME=admin
# 首次部署密码长度需 >= 8 位，否则拒绝创建（调试可置 ALLOW_WEAK_ADMIN_PASSWORD=true 放行）。
ADMIN_PASSWORD=请设置一个强密码（至少 8 位）
ALLOW_WEAK_ADMIN_PASSWORD=false

# --- 多账户 ---
# 是否开放用户自助注册（false = 仅管理员创建用户）
ALLOW_REGISTER=true
# 新用户默认存储配额（MB），0 = 无限
DEFAULT_QUOTA_MB=0

# --- 数据存储（文件 + 数据库 + 向量索引 都在这下面）---
# 建议 /data 挂载到加密卷（LUKS/dm-crypt），见 docs/DEPLOY_SECURITY.md。
# docker-compose.yml 把主机 ${DATA_DIR} 挂载到容器 /data，
# 故容器内路径直接用 /data/... 即落盘到主机 ${DATA_DIR} 下。
# 注意：DATA_DIR 仅供 docker-compose 卷映射使用，应用代码不读取它。
DATA_DIR=/data/suixingdang
STORAGE_DIR=/data/files
DATABASE_PATH=/data/db.sqlite
# 升级提示：旧版模板曾用 /data/suixingdang/files 等嵌套路径。若你已按旧路径部署，
# 不要直接改成上面的新路径——需先把已有数据移动到新位置，否则服务会找不到旧数据。

# --- 嵌入模型（语义搜索用）---
EMBEDDING_PROVIDER=default
# default = ChromaDB 内置 all-MiniLM-L6-v2（零配置）
# openai = OpenAI Embedding API（复用管理后台默认大模型的 API Key）
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
