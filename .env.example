 # ============================================
 # 随行档 - 环境变量配置模板
 # 复制为 .env 并填写实际值
 # ============================================
 
 # --- 服务器配置 ---
 DOMAIN=files.yourdomain.com
 SECRET_KEY=请替换为一个随机长字符串（openssl rand -hex 32）
 
 # --- 管理员账户（首次启动自动创建）---
 ADMIN_USERNAME=admin
 ADMIN_PASSWORD=请设置一个强密码
 
 # --- 数据存储（文件 + 数据库 + 向量索引 都在这下面）---
 DATA_DIR=/data/suixingdang
 STORAGE_DIR=/data/suixingdang/files
 DATABASE_PATH=/data/suixingdang/db.sqlite
 
 # --- LLM 配置 ---
 # 支持 DeepSeek 和 OpenAI
 LLM_PROVIDER=deepseek
 DEEPSEEK_API_KEY=你的DeepSeek密钥
 DEEPSEEK_BASE_URL=https://api.deepseek.com
 DEEPSEEK_MODEL=deepseek-chat
 
 # 如果用 OpenAI，取消注释：
 # LLM_PROVIDER=openai
 # OPENAI_API_KEY=你的OpenAI密钥
 # OPENAI_BASE_URL=https://api.openai.com/v1
 # OPENAI_MODEL=gpt-4o-mini
 
 # --- 嵌入模型（语义搜索用）---
 EMBEDDING_PROVIDER=deepseek
 # DeepSeek 暂不支持 embedding，如果需要语义搜索可用 OpenAI 或本地模型
 # EMBEDDING_PROVIDER=openai
 # OPENAI_EMBEDDING_MODEL=text-embedding-3-small
