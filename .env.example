 # ============================================
 # 随行档 - 环境变量配置模板
 # 复制为 .env 并填写实际值
 # ============================================
 
 # --- 服务器配置 ---
 DOMAIN=files.yourdomain.com
 SECRET_KEY=请替换为一个随机长字符串（openssl rand -hex 32）
 
 # --- 管理员账户（首次启动自动创建）---
 ADMIN_USERNAME=admin
 ADMIN_PASSWORD=请设置一个强密码
 
# --- 数据存储（文件 + 数据库 + 向量索引 都在这下面）---
DATA_DIR=/data/suixingdang
STORAGE_DIR=/data/suixingdang/files
DATABASE_PATH=/data/suixingdang/db.sqlite

# --- LLM 配置 ---
# 大模型配置已迁移到管理后台（「大模型配置」页面）。
# 首次启动时，若 env 中仍有旧版 LLM_* / DEEPSEEK_* / OPENAI_* 变量，
# 系统会自动将其迁移到数据库，之后请在管理后台维护。
#
# --- 嵌入模型（语义搜索用）---
EMBEDDING_PROVIDER=default
# default = ChromaDB 内置 all-MiniLM-L6-v2（零配置）
# openai = OpenAI Embedding API（复用管理后台默认大模型的 API Key）
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
