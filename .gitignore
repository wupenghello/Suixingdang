# 环境变量 / 密钥：忽略所有 .env*，但保留模板（.env.example / .env.test / 各目录下的 .env.example）
.env*
!.env.example
!.env.test

# 运行时数据（数据库、用户文件、缓存、日志）
/data/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# 本地工具配置
.claude/

# Node / 本地截图脚本（仅本地开发用，不入库）
node_modules/
# 新前端构建产物（CI/部署时构建，不入库）
web/dist/
# 锚定仓库根：根 package.json(playwright 截图脚本)不入库；server/package.json 是正式前端工具链，须入库供 CI 使用
/package.json
/package-lock.json
sxd_*.mjs

# 测试产物
test-results/
**/test-results/
coverage/
**/coverage/

# 系统文件
.DS_Store
