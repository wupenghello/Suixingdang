# {$DOMAIN} 由 Caddy 从环境变量自动读取（在 .env 中设置 DOMAIN，docker-compose 已注入）
# Caddy 会自动申请并续期 Let's Encrypt HTTPS 证书

{$DOMAIN} {
	reverse_proxy server:8000

	# 上传文件大小限制（500MB）
	request_body {
		max_size 500MB
	}

	# 压缩
	encode gzip zstd

	# 安全头
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# 前端为原生 ES Module SPA：脚本/样式/字体均来自 self 与 Google Fonts，
		# 其余外部源一律拒绝；object-src none 禁用插件，frame-ancestors none 防点击劫持。
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
	}

	# HTML 入口禁用启发式缓存：部署后浏览器每次协商验证，立即拿到新入口，
	# 不再出现"合并了但页面还是旧的"（此前无 Cache-Control，浏览器按
	# Last-Modified 启发式缓存落地页，旧 HTML 继续引用旧版资源）。
	# Caddy 没有按响应头匹配的 matcher（header_resp 不存在），用请求路径
	# 反向排除：带版本化静态资源的路径（用户端 /assets/* 内容 hash、管理后台
	# /admin/assets/* 手动 ?v=）与 API 之外全部 no-cache，自然覆盖 SPA 所有
	# 深链入口（/、/admin*、/welcome 等）。
	@html {
		not path /api/* /assets/* /admin/assets/* /landing.css
	}
	header @html Cache-Control "no-cache"

	log {
		output file /data/access.log
	}
}
