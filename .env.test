# 仅本地开发/测试占位值，无真实密钥，勿用于生产部署。
# 真实部署请复制 .env.example 为 .env 并填写实际值。
DOMAIN=localhost
ENV=dev
ENABLE_API_DOCS=true
SECRET_KEY=test-secret-key-for-local-dev-only
JWT_SECRET=test-jwt-secret-for-local-dev-only
DATA_ENCRYPTION_KEY=test-data-encryption-key-local-dev
ADMIN_USERNAME=admin
ADMIN_PASSWORD=test123456
STORAGE_DIR=/tmp/suixingdang-test/files
DATABASE_PATH=/tmp/suixingdang-test/db.sqlite
EMBEDDING_PROVIDER=default
